{
  "compilerOptions": {
    "target": "ES2020",
    "module": "preserve",
    "lib": [
      "ES2020"
    ],
    "strict": true,
    "outDir": "./out",
    "rootDir": "./src",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "types": [
      "node"
    ],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "out"
  ]
}