{
  "name": "python-docstring-generator",
  "displayName": "Python Docstring Generator",
  "description": "Automatically generate and update Python docstrings in Google, NumPy, or Sphinx format..",
  "version": "0.1.0",
  "publisher": "pmason314",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pmason314/docdoc"
  },
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters",
    "Other"
  ],
  "keywords": [
    "python",
    "docstring",
    "documentation",
    "google",
    "numpy",
    "sphinx"
  ],
  "activationEvents": [
    "onLanguage:python"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "docstringGenerator.generate",
        "title": "Python: Generate Docstring"
      },
      {
        "command": "docstringGenerator.generateFile",
        "title": "Python: Generate Docstrings for File"
      },
      {
        "command": "docstringGenerator.update",
        "title": "Python: Update Docstring"
      },
      {
        "command": "docstringGenerator.updateFile",
        "title": "Python: Update All Docstrings in File"
      },
      {
        "command": "docstringGenerator.convertFormat",
        "title": "Python: Convert Docstring Format"
      },
      {
        "command": "docstringGenerator.convertFileFormat",
        "title": "Python: Convert All Docstrings in File"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "docstringGenerator.generate",
          "when": "editorLangId == python"
        },
        {
          "command": "docstringGenerator.generateFile",
          "when": "editorLangId == python"
        },
        {
          "command": "docstringGenerator.update",
          "when": "editorLangId == python"
        },
        {
          "command": "docstringGenerator.updateFile",
          "when": "editorLangId == python"
        },
        {
          "command": "docstringGenerator.convertFormat",
          "when": "editorLangId == python"
        },
        {
          "command": "docstringGenerator.convertFileFormat",
          "when": "editorLangId == python"
        }
      ]
    },
    "configuration": {
      "title": "Python Docstring Generator",
      "properties": {
        "docstringGenerator.format": {
          "type": "string",
          "default": "",
          "enum": [
            "",
            "google",
            "numpy",
            "sphinx"
          ],
          "enumDescriptions": [
            "Auto-detect from pyproject.toml; falls back to Google",
            "Google style",
            "NumPy style",
            "Sphinx / reStructuredText style"
          ],
          "description": "Docstring format. If empty, auto-detected from pyproject.toml; falls back to Google."
        },
        "docstringGenerator.quoteStyle": {
          "type": "string",
          "default": "double",
          "enum": [
            "double",
            "single"
          ],
          "enumDescriptions": [
            "Use \"\"\" (double quotes)",
            "Use ''' (single quotes)"
          ],
          "description": "Quote style for generated docstrings."
        },
        "docstringGenerator.onSave.enable": {
          "type": "boolean",
          "default": false,
          "description": "Generate docstrings for all undocumented functions and classes on file save."
        },
        "docstringGenerator.includeTypesFromAnnotations": {
          "type": "boolean",
          "default": true,
          "description": "Include type info in the docstring when a type annotation is present in the signature."
        },
        "docstringGenerator.includeDefaults": {
          "type": "boolean",
          "default": true,
          "description": "Append 'Defaults to X.' in the parameter description when a default value is present."
        },
        "docstringGenerator.returns.mode": {
          "type": "string",
          "default": "when-annotated",
          "enum": [
            "when-annotated",
            "non-none",
            "always"
          ],
          "enumDescriptions": [
            "Emit Returns only when a non-None return annotation is present.",
            "Emit Returns for any non-None annotation; skip if unannotated or -> None.",
            "Always emit Returns, even for unannotated functions and -> None."
          ],
          "description": "When to emit a Returns (or Yields) section."
        },
        "docstringGenerator.generateModuleDocstring": {
          "type": "boolean",
          "default": false,
          "description": "When running Generate Docstrings for File, also insert a module-level docstring if the file does not already have one."
        },
        "docstringGenerator.placeholders.summary": {
          "type": "string",
          "default": "_summary_",
          "description": "Placeholder text for the summary line."
        },
        "docstringGenerator.placeholders.description": {
          "type": "string",
          "default": "_description_",
          "description": "Placeholder text for parameter and return descriptions."
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "NODE_ENV=production node esbuild.js",
    "vscode:prepublish": "npm run package",
    "lint": "eslint src/",
    "test:unit": "mocha --spec 'src/test/unit/**/*.test.ts'",
    "test:integration": "mocha --spec 'src/test/integration/**/*.test.ts'",
    "test:all": "mocha",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.0",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.104.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.0.0",
    "mocha": "^11.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "smol-toml": "^1.3.0",
    "tree-sitter-python": "^0.25.0",
    "web-tree-sitter": "^0.26.8"
  }
}