{
  "name": "docdoc",
  "displayName": "Docdoc - Automatic Python Docstrings",
  "description": "Automatically generate and update Python docstrings in Google, NumPy, or Sphinx format..",
  "version": "0.1.3",
  "publisher": "pmason314",
  "icon": "resources/docdoc-icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pmason314/docdoc"
  },
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters",
    "Other"
  ],
  "keywords": [
    "python",
    "docstring",
    "documentation",
    "google",
    "numpy",
    "sphinx"
  ],
  "activationEvents": [
    "onLanguage:python"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "docdoc.generate",
        "title": "Python: Generate Docstring"
      },
      {
        "command": "docdoc.generateFile",
        "title": "Python: Generate All Docstrings for File"
      },
      {
        "command": "docdoc.update",
        "title": "Python: Update Docstring"
      },
      {
        "command": "docdoc.updateFile",
        "title": "Python: Update All Docstrings in File"
      },
      {
        "command": "docdoc.convertFormat",
        "title": "Python: Convert Docstring Format"
      },
      {
        "command": "docdoc.convertFileFormat",
        "title": "Python: Convert All Docstrings in File"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "docdoc.generate",
          "when": "editorLangId == python"
        },
        {
          "command": "docdoc.generateFile",
          "when": "editorLangId == python"
        },
        {
          "command": "docdoc.update",
          "when": "editorLangId == python"
        },
        {
          "command": "docdoc.updateFile",
          "when": "editorLangId == python"
        },
        {
          "command": "docdoc.convertFormat",
          "when": "editorLangId == python"
        },
        {
          "command": "docdoc.convertFileFormat",
          "when": "editorLangId == python"
        }
      ]
    },
    "configuration": {
      "title": "Docdoc - Python Docstring Generator",
      "properties": {
        "docdoc.format": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "google",
            "numpy",
            "sphinx"
          ],
          "enumDescriptions": [
            "Auto-detect from pyproject.toml; default to Google style if no docstring setting found",
            "Google style",
            "NumPy style",
            "Sphinx / reStructuredText style"
          ],
          "description": "Python docstring format."
        },
        "docdoc.quoteStyle": {
          "type": "string",
          "default": "double",
          "enum": [
            "double",
            "single"
          ],
          "enumDescriptions": [
            "Use \"\"\" (double quotes)",
            "Use ''' (single quotes)"
          ],
          "description": "Quote style for generated docstrings."
        },
        "docdoc.onSave.enable": {
          "type": "boolean",
          "default": false,
          "description": "Generate docstrings for all undocumented functions and classes on file save."
        },
        "docdoc.includeTypesFromAnnotations": {
          "type": "boolean",
          "default": true,
          "description": "Include data type info in the docstring when a type annotation is present in the function or class signature."
        },
        "docdoc.includeDefaults": {
          "type": "boolean",
          "default": true,
          "description": "Append 'Defaults to X.' in the parameter description when a default parameter value is present."
        },
        "docdoc.returns.mode": {
          "type": "string",
          "default": "always",
          "enum": [
            "always",
            "non-none"
          ],
          "enumDescriptions": [
            "Always include a Returns or Yields section.",
            "Only include a Returns section when the function has a non-None return annotation."
          ],
          "description": "When to include a Returns (or Yields) section in the docstring."
        },
        "docdoc.generateModuleDocstring": {
          "type": "boolean",
          "default": true,
          "description": "When running the  'Generate All Docstrings for File' command, also insert a module-level docstring if the file does not already have one."
        },
        "docdoc.placeholders.summary": {
          "type": "string",
          "default": "_summary_",
          "description": "Placeholder text for the docstring's summary line."
        },
        "docdoc.placeholders.description": {
          "type": "string",
          "default": "_description_",
          "description": "Placeholder text for the docstring's parameter and return descriptions."
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "NODE_ENV=production node esbuild.js",
    "vscode:prepublish": "npm run package",
    "lint": "eslint src/",
    "test:unit": "mocha --spec 'src/test/unit/**/*.test.ts'",
    "test:integration": "mocha --spec 'src/test/integration/**/*.test.ts'",
    "test:all": "mocha",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.0",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.104.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.0.0",
    "mocha": "^11.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "smol-toml": "^1.3.0",
    "tree-sitter-python": "^0.25.0",
    "web-tree-sitter": "^0.26.8"
  }
}
